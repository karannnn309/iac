provider "aws" {
  region = "us-east-1"
}

# Data source to fetch the latest Amazon Linux 2 AMI for security and maintainability.
# This ensures instances are launched with the most up-to-date and patched OS.
data "aws_ami" "amazon_linux_2" {
  most_recent = true
  owners      = ["amazon"]

  filter {
    name   = "name"
    values = ["amzn2-ami-hvm-*-x86_64-gp2"]
  }

  filter {
    name   = "virtualization-type"
    values = ["hvm"]
  }
}

resource "aws_instance" "web_server" {
  # Use the dynamically fetched AMI ID for security and maintainability
  ami           = data.aws_ami.amazon_linux_2.id
  instance_type = "t2.micro"

  tags = {
    Name        = "web-server" # Corrected missing quotes
    Environment = "dev"
  }

  # Use a variable for the key pair name for better security and management
  key_name = var.key_name

  # Reference security group by ID for robustness and VPC association
  vpc_security_group_ids = [aws_security_group.web_sg.id]

  # Corrected count to an integer type
  count = 2
}

resource "aws_security_group" "web_sg" {
  name        = "web_sg"
  description = "Allow HTTP inbound traffic and restricted outbound traffic"
  # Associate with a specific VPC for best practice; use var.vpc_id
  vpc_id      = var.vpc_id 

  # Restrict inbound HTTP access.
  # This uses a dynamic block to allow multiple CIDRs or no ingress if the list is empty.
  # For a truly public web server, if 0.0.0.0/0 on 80/443 is needed, it's CRUCIAL
  # to place the instance behind an Application Load Balancer (ALB) and a WAF.
  # For direct instance exposure, restricting to known IPs is much safer.
  dynamic "ingress" {
    for_each = var.allowed_web_ingress_cidrs
    content {
      from_port   = 80
      to_port     = 80
      protocol    = "tcp" # Corrected missing quotes
      cidr_blocks = [ingress.value]
      description = "Allow HTTP from specific CIDR"
    }
  }

  # Restricted egress: allow only HTTPS traffic for updates/APIs to anywhere.
  # This is more secure than allowing all ports/protocols.
  egress {
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
    description = "Allow HTTPS outbound to the internet"
  }

  # Optionally, allow ICMP for basic ping/health checks for diagnostic purposes.
  egress {
    from_port   = -1 # All ICMP types
    to_port     = -1 # All ICMP codes
    protocol    = "icmp"
    cidr_blocks = ["0.0.0.0/0"]
    description = "Allow ICMP outbound to the internet"
  }
}

# Variables for better security, flexibility, and maintainability

variable "key_name" {
  description = "The name of the EC2 Key Pair to allow SSH access. This should be securely managed."
  type        = string
}

variable "allowed_web_ingress_cidrs" {
  description = "List of CIDR blocks allowed for inbound HTTP (port 80). Set [\"0.0.0.0/0\"] for public access ONLY IF the instance is behind an ALB/WAF. Default is an empty list, meaning no public access."
  type        = list(string)
  default     = [] # Secure by default: no public ingress unless explicitly defined
  # Example for restricted access: default = ["your.office.public.ip/32"]
}

variable "vpc_id" {
  description = "The ID of the VPC where the security group and instances will be created. It's best practice to explicitly define this."
  type        = string
  # Consider using a data source to fetch an existing VPC ID dynamically if applicable.
  # default = "vpc-xxxxxxxxxxxxxxxxx" # Example if you want a default VPC ID
}
